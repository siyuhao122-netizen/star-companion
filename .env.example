# Flask
SECRET_KEY=your-secret-key-change-this

# SQLite 数据库路径（相对于 backend/ 目录）
DATABASE_URL=sqlite:///star_companion.db

# QQ邮箱 SMTP
MAIL_USERNAME=your-qq-email@qq.com
MAIL_PASSWORD=your-smtp-password

# 阿里云百炼 AI (问卷分析 / 树洞 / 叫名反应 / 声音小话筒)
BAILIAN_API_KEY=sk-your-bailian-key
BAILIAN_MODEL=qwen-turbo
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 阿里云百炼 AI (指物练习专用微调模型)
POINT_GAME_AI_API_KEY=sk-your-point-game-key
POINT_GAME_AI_MODEL=qwen3-8b-your-model-id
POINT_GAME_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 阿里云百炼知识库 (RAG - 在百炼控制台创建知识库后获取)
BAILIAN_WORKSPACE_ID=your-workspace-id
BAILIAN_INDEX_ID=your-index-id

# 阿里云语音识别
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_APP_KEY=your-app-key
ALIYUN_REGION=cn-shanghai
